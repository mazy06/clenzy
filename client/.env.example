# Clenzy PMS - Variables d'environnement
# Copier ce fichier en .env.development ou .env.production et adapter les valeurs

# API Backend
VITE_API_BASE_URL=http://localhost:8084
VITE_API_BASE_PATH=/api

# Keycloak Authentication
VITE_KEYCLOAK_URL=http://localhost:8083
VITE_KEYCLOAK_REALM=clenzy
VITE_KEYCLOAK_CLIENT_ID=clenzy-web

# Application
VITE_APP_NAME=Clenzy
VITE_APP_VERSION=1.0.0

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME

# Mapbox — Carte propriété
VITE_MAPBOX_TOKEN=

# PostHog — Product Analytics & Session Replay
# Create a project on https://eu.posthog.com and paste your Project API Key here
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Sentry — Error tracking
VITE_SENTRY_DSN=

# Crisp — Live chat support
VITE_CRISP_WEBSITE_ID=

# Cloudflare Turnstile — CAPTCHA
VITE_TURNSTILE_SITE_KEY=
