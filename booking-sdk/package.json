{
  "name": "@clenzy/booking-sdk",
  "version": "1.0.0",
  "description": "Clenzy Booking Engine — Headless JavaScript SDK",
  "type": "module",
  "main": "dist/clenzy-booking.cjs.js",
  "module": "dist/clenzy-booking.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/clenzy-booking.esm.js",
      "require": "./dist/clenzy-booking.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^3.9.0"
  },
  "keywords": [
    "booking",
    "reservation",
    "headless",
    "sdk",
    "clenzy"
  ],
  "license": "UNLICENSED",
  "sideEffects": false
}
